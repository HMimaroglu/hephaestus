# Node Configuration
NODE_NAME=hephaestus-node
HOST=0.0.0.0
PORT=8000

# Discovery
DISCOVERY_PORT=9000
DISCOVERY_MULTICAST_GROUP=224.0.0.251
DISCOVERY_MULTICAST_TTL=2
DISCOVERY_INTERVAL=5
PEER_TIMEOUT=30

# WebSocket
WS_PORT=8001

# Seed Node Configuration
IS_SEED_NODE=false
SEED_NODE_URL=
PUBLIC_IP=

# Roles
INITIAL_ROLES=["researcher"]
MAX_LOAD_THRESHOLD=0.8
MIN_QOS_THRESHOLD=0.5

# LLM Configuration
LLM_BACKEND=ollama
LLM_MODEL=llama3.2:3b
LLM_HOST=http://localhost:11434
LLM_TIMEOUT=120

# Logging
LOG_LEVEL=INFO
