# Hephaestus - WiFi Hotspot (Offline) Configuration
# Use this configuration for fully offline operation via WiFi hotspot
#
# SETUP:
# 1. Host computer creates WiFi hotspot (see README for OS instructions)
# 2. Client devices connect to the hotspot WiFi
# 3. Copy this file to .env and run: python -m backend.app
# 4. Nodes auto-discover each other via multicast (no internet needed)

# Node Configuration
NODE_NAME=hephaestus-node
HOST=0.0.0.0
PORT=8000

# Discovery (Local Multicast - No Internet Required)
DISCOVERY_PORT=9000
DISCOVERY_MULTICAST_GROUP=224.0.0.251
DISCOVERY_MULTICAST_TTL=2
DISCOVERY_INTERVAL=5
PEER_TIMEOUT=30

# WebSocket
WS_PORT=8001

# Seed Node - Leave empty for offline hotspot mode
IS_SEED_NODE=false
SEED_NODE_URL=
PUBLIC_IP=

# Roles (customize per node)
# Host computer: INITIAL_ROLES=["researcher","programmer","presenter"]
# Client devices: INITIAL_ROLES=["programmer"] or ["researcher"]
INITIAL_ROLES=["researcher"]
MAX_LOAD_THRESHOLD=0.8
MIN_QOS_THRESHOLD=0.5

# LLM Configuration
# Each device needs its own Ollama instance running locally
LLM_BACKEND=ollama
LLM_MODEL=llama3.2:3b
LLM_HOST=http://localhost:11434
LLM_TIMEOUT=120

# Logging
LOG_LEVEL=INFO
